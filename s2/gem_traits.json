{
  "_metadata": {
    "version": "s2-2026-05-26",
    "source": "Merged from game_data/s2/csv_files/GemConstants.csv + in-game tooltips 2026-05-25 + observed log buff names from 10-log cohort",
    "note": "Methodology (gem economy, slot strategy, orb interactions, Harmonious Soul decay) lives in the sibling memory/reference_gem_powers.md"
  },

  "constants": {
    "global_gem_power_cap": 2640,
    "global_gem_power_cap_note": "NOT a hard cap. Going over IS allowed. Past 2640 you stop unlocking new traits, but each overcap point still grants the small overcap bonus.",
    "overcap_bonus_multiplier": 0.00005,
    "overcap_formula": "0.00005 × overcap_points = fractional primary stat + HP bonus (e.g. 114 overcap = +0.57% main stat)",
    "trait_unlock_thresholds": [120, 240, 480, 720, 960, 1200, 1560, 1920, 2280, 2640]
  },

  "slot_multipliers": {
    "standard":  {"multiplier": 1.0},
    "upgraded":  {"multiplier": 1.35, "note": "Rare-drop slot"},
    "legendary": {"multiplier": 2.0,  "equip_limit_per_character": 1}
  },

  "slot_count_per_archetype": {
    "0_set":       11,
    "1_2pc":        9,
    "2_2pc":        7,
    "triple_2pc":   5,
    "note": "Set pieces have NO gem slots. Each set 2pc commitment = 2 fewer gem-eligible gear pieces."
  },

  "naming_inconsistency": {
    "rule": "Rank-5 trait tooltip uses 'Blessing of the X' but the buff fires in logs as 'Essence of the X'. Rank-10 tooltip says 'Blessing of the X - II' and fires in logs as 'Blessing of the X - II'.",
    "implication": "When matching FSL buff events to a gem trait, both 'Blessing' (rank 10+) and 'Essence' (rank 5-9) need to be in the lookup."
  },

